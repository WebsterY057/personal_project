.page{padding:0 30rpx 30rpx;background:var(--bg);min-height:100vh}

.hero{
  background:var(--hero-bg);
  border-radius:var(--radius-lg);
  padding:28rpx 32rpx;
  margin-bottom:24rpx;
  border:1rpx solid var(--border);
  display:flex;align-items:center;gap:20rpx
}
.hero-title{
  display:block;
  font-size:36rpx;font-weight:400;
  color:var(--warm);letter-spacing:2rpx;
  line-height:1.4
}
.hero-sub{display:block;font-size:24rpx;color:var(--text-muted);margin-top:4rpx}
.hero-points{color:var(--warm);font-weight:700}

.elist{display:flex;flex-direction:column;gap:16rpx}
.ecard{
  display:flex;align-items:center;gap:20rpx;
  background:var(--bg-card);
  border-radius:var(--radius);
  padding:28rpx 24rpx;
  border:1rpx solid var(--border)
}
.ecard:active{background:var(--bg-card-hover)}
.ecard-locked{opacity:0.45}
.eemoji{font-size:40rpx;flex-shrink:0}
.einfo{flex:1;min-width:0}
.ename{font-size:28rpx;font-weight:600;color:var(--text);display:block;margin-bottom:4rpx}
.edesc{font-size:22rpx;color:var(--text-muted);display:block;line-height:1.5}
.epoints{flex-shrink:0;text-align:center}
.ep-num{display:block;font-size:36rpx;font-weight:700;color:var(--primary)}
.ep-label{display:block;font-size:20rpx;color:var(--text-muted)}

.tip{
  display:flex;align-items:center;gap:10rpx;
  background:var(--surface);
  border-radius:var(--radius-sm);
  padding:20rpx 24rpx;
  margin:24rpx 0 40rpx
}
.tip-icon{font-size:28rpx;flex-shrink:0}
.tip-text{font-size:22rpx;color:var(--text-muted);line-height:1.6}
