<view class="page {{_pageClass}}">
  <!-- Hero Header -->
  <view class="hero">
    <view class="brand-logo">
      <image class="brand-logo-icon" src="/images/food_a.png" mode="aspectFit"/>
    </view>
    <view class="hero-text">
      <text class="hero-title">食材查询</text>
      <text class="hero-sub">按体质 · 属性 · 归经筛选</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-wrap">
    <text class="si">🔍</text>
    <input class="sin" placeholder="搜索食材名称、功效..." bindinput="onSearch" />
  </view>

  <!-- 筛选行 -->
  <view class="frow"><scroll-view class="fscroll" scroll-x><text class="flabel">体质</text><view class="chip {{filter===item?'act':''}}" wx:for="{{filters}}" wx:key="*this" data-value="{{item}}" bindtap="setFilter">{{item}}</view></scroll-view></view>
  <view class="frow"><scroll-view class="fscroll" scroll-x><text class="flabel">属性</text><view class="chip chip2 {{propertyFilter===item?'act':''}}" wx:for="{{properties}}" wx:key="*this" data-value="{{item}}" bindtap="setProperty">{{item}}</view></scroll-view></view>
  <view class="frow"><scroll-view class="fscroll" scroll-x><text class="flabel">归经</text><view class="chip chip2 {{meridianFilter===item?'act':''}}" wx:for="{{meridians}}" wx:key="*this" data-value="{{item}}" bindtap="setMeridian">{{item}}</view></scroll-view></view>

  <!-- 结果列表 -->
  <view class="flist">
    <view wx:if="{{!hasData}}"><text class="empty">完整食材数据请查看H5版</text></view>
    <view wx:elif="{{filtered.length===0}}"><text class="empty">未找到匹配食材</text></view>
    <view class="fcard" wx:for="{{filtered}}" wx:key="name" data-name="{{item.name}}" bindtap="toggleCard">
      <view class="fch">
        <view class="fci">
          <text class="femoji">{{item.typeEmoji || '🥬'}}</text>
          <view>
            <text class="fn">{{item.name}}</text>
            <view class="ftags">
              <text class="ftag" wx:if="{{item.property}}">{{item.property}}</text>
              <text class="ftag" wx:if="{{item.flavor}}">{{item.flavor}}</text>
              <text class="ftag" wx:for="{{item.meridian}}" wx:for-item="m" wx:key="*this">{{m}}</text>
            </view>
          </view>
        </view>
        <view class="fca">
          <view class="badge {{item.suit==='宜食'?'bg':'br'}}" wx:if="{{item.suit}}">{{item.suit}}</view>
          <view class="fav {{item.favorite?'faved':''}}" data-name="{{item.name}}" catchtap="toggleFavorite">{{item.favorite ? '★' : '☆'}}</view>
        </view>
      </view>
      <view class="fbody" wx:if="{{expanded[item.name]}}">
        <view class="fd" wx:if="{{item.nutrition}}"><text class="fl">营养</text><text>{{item.nutrition}}</text></view>
        <view class="fd" wx:if="{{item.pairing}}"><text class="fl">搭配</text><text>{{item.pairing}}</text></view>
        <view class="fd" wx:if="{{item.mechanism}}"><text class="fl">功效</text><text>{{item.mechanism}}</text></view>
        <view class="fd" wx:if="{{item.suitable}}"><text class="fl">适宜</text><text>{{item.suitable}}</text></view>
        <view class="fd" wx:if="{{item.avoid}}"><text class="fl">禁忌</text><text>{{item.avoid}}</text></view>
      </view>
    </view>
  </view>
</view>
