.container{padding:40rpx 30rpx}
.title{font-size:40rpx;font-weight:700;display:block}
.subtitle{font-size:26rpx;color:var(--text-secondary);display:block;margin:10rpx 0 40rpx}
.form-item{background:var(--surface);border-radius:var(--radius);padding:24rpx 28rpx;margin-bottom:20rpx;display:flex;align-items:center;justify-content:space-between}
.label{font-size:30rpx}
.input{font-size:28rpx;text-align:right;color:var(--text);flex:1;margin-left:20rpx}
.picker{font-size:28rpx}
.picker-value{color:var(--primary)}
.submit-btn{background:var(--primary);color:#fff;border:none;border-radius:var(--radius);padding:28rpx;font-size:32rpx;margin-top:30rpx;width:100%;box-sizing:border-box}
