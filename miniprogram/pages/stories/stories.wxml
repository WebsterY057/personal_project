<scroll-view scroll-y style="height:100vh;padding:20rpx 30rpx;">
  <view style="font-size:36rpx;font-weight:700;margin-bottom:8rpx;">📜 中药故事</view>
  <view style="font-size:24rpx;color:var(--text-muted);margin-bottom:24rpx;">古人的智慧 · 药中的传奇</view>

  <view wx:for="{{stories}}" wx:key="id" data-id="{{item.id}}" bindtap="showStory" style="background:var(--bg-card);border-radius:16rpx;padding:24rpx;margin-bottom:16rpx;border:1rpx solid var(--border);">
    <view style="font-size:28rpx;font-weight:600;">{{item.herb}} · {{item.title}}</view>
    <view style="font-size:24rpx;color:var(--text-secondary);margin-top:8rpx;line-height:1.6;">{{item.summary}}</view>
    <view style="font-size:22rpx;color:var(--text-muted);margin-top:8rpx;">📖 {{item.source}}</view>
  </view>

  <!-- Detail modal -->
  <view wx:if="{{current}}" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.6);z-index:999;display:flex;align-items:center;justify-content:center;padding:30rpx;" bindtap="closeDetail">
    <view style="background:var(--bg-card);border-radius:16rpx;padding:30rpx;max-width:700rpx;width:100%;max-height:80vh;overflow-y:auto;" catchtap="">
      <view style="font-size:32rpx;font-weight:700;margin-bottom:8rpx;">📜 {{current.herb}} · {{current.title}}</view>
      <view style="font-size:24rpx;color:var(--accent);margin-bottom:16rpx;">{{current.source}}</view>
      <view style="font-size:26rpx;color:var(--text-secondary);line-height:1.8;white-space:pre-wrap;">{{current.story}}</view>
      <view style="margin-top:20rpx;padding:16rpx;background:rgba(76,175,80,0.08);border-radius:10rpx;">
        <view style="font-size:22rpx;color:var(--primary);font-weight:600;">💡 养生启示</view>
        <view style="font-size:24rpx;color:var(--text-secondary);margin-top:6rpx;line-height:1.6;">{{current.lesson}}</view>
      </view>
      <view style="display:flex;gap:10rpx;margin-top:16rpx;flex-wrap:wrap;">
        <view wx:for="{{current.relatedHerbs}}" wx:key="this" style="background:var(--surface);padding:6rpx 16rpx;border-radius:20rpx;font-size:22rpx;color:var(--text-muted);">🌿 {{item}}</view>
      </view>
      <view style="text-align:center;margin-top:20rpx;color:var(--text-muted);font-size:24rpx;" bindtap="closeDetail">点击关闭</view>
    </view>
  </view>
</scroll-view>
