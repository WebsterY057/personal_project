.page{padding:0 30rpx 30rpx}

/* 季节 Tab */
.tabs{
  display:flex;gap:12rpx;
  margin-bottom:24rpx
}
.tab{
  flex:1;padding:16rpx 0;text-align:center;
  border-radius:var(--radius);
  background:var(--surface);
  font-size:26rpx;color:var(--text-secondary)
}
.tab.active{color:#fff;font-weight:600}

/* 定位信息 */
.location-bar{
  background:var(--bg-card);
  border-radius:var(--radius-lg);
  padding:18rpx 24rpx;
  margin-bottom:16rpx;
  display:flex;align-items:center;gap:10rpx;
  border:1rpx solid rgba(168,201,154,0.15)
}
.loc-icon{font-size:28rpx;flex-shrink:0}
.loc-text{font-size:24rpx;color:var(--text-secondary);line-height:1.5}

/* 养生 Banner */
.banner{
  background:var(--bg-card);
  border-radius:var(--radius-lg);
  padding:28rpx 32rpx;
  margin-bottom:24rpx;
  border:1rpx solid rgba(255,255,255,0.04)
}
.btitle{
  font-size:30rpx;font-weight:bold;
  display:block;margin-bottom:8rpx;
  font-family:KaiTi,STKaiti,serif
}
.bstip{
  font-size:25rpx;color:var(--text-secondary);line-height:1.6
}

/* Section */
.section{margin-bottom:28rpx}
.section-hd{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:16rpx
}
.sh-title{font-size:30rpx;font-weight:bold;color:var(--text)}
.sh-count{
  font-size:22rpx;color:var(--text-muted);
  background:var(--surface);padding:4rpx 14rpx;border-radius:20rpx
}

/* 食谱列表 */
.recipe-list{
  display:flex;flex-direction:column;gap:14rpx
}
.rcard{
  background:var(--bg-card);
  border-radius:var(--radius);
  padding:24rpx 28rpx;
  display:flex;align-items:center;justify-content:space-between;
  border:1rpx solid rgba(255,255,255,0.04);
  transition:background .15s
}
.rcard:active{background:var(--surface)}
.rcard-l{flex:1}
.rname{
  font-size:30rpx;font-weight:bold;
  color:var(--text);display:block;margin-bottom:6rpx
}
.r-meta{display:flex;gap:20rpx}
.rmeta{font-size:22rpx;color:var(--text-muted)}
.rcard-r{flex-shrink:0;padding-left:16rpx}
.rarr{font-size:36rpx;color:var(--text-muted)}

/* 食材标签 */
.ftags{display:flex;flex-wrap:wrap;gap:10rpx}
.tag{
  display:inline-block;
  padding:8rpx 20rpx;border-radius:20rpx;
  font-size:24rpx;
  background:rgba(76,175,80,.12);color:var(--primary)
}
.tag-f{background:rgba(33,150,243,.12);color:#42A5F5}

/* 体质提示 */
.constitution-tip{
  background:var(--bg-card);
  border-radius:var(--radius);
  padding:24rpx 28rpx;
  border-left:6rpx solid var(--primary);
  margin-bottom:20rpx
}
.ctip-title{font-size:26rpx;font-weight:600;display:block;margin-bottom:6rpx;color:var(--text)}
.ctip-text{font-size:25rpx;color:var(--text-secondary);line-height:1.6}

/* 弹窗（复用 recipes.wxss 风格） */
.modal-overlay{
  position:fixed;top:0;left:0;right:0;bottom:0;
  background:rgba(0,0,0,.65);z-index:100
}
.modal{
  background:var(--bg);
  border-radius:var(--radius-lg);
  margin:100rpx 30rpx;
  padding:32rpx;
  max-height:75vh;overflow-y:auto
}
.modal-hd{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:24rpx;padding-bottom:16rpx;
  border-bottom:1rpx solid rgba(255,255,255,0.06)
}
.modal-title{
  font-size:32rpx;font-weight:bold;
  font-family:KaiTi,STKaiti,serif;letter-spacing:1rpx;
  color:var(--accent)
}
.modal-close{font-size:36rpx;color:var(--text-muted);padding:10rpx}
.modal-bd{
  max-height:60vh;overflow-y:auto;
  -webkit-overflow-scrolling:touch
}
.ms{margin-bottom:24rpx}
.ml{
  font-weight:bold;color:var(--accent);
  display:block;margin-bottom:12rpx;font-size:26rpx
}
.ilist{display:flex;flex-wrap:wrap;gap:10rpx;margin-top:8rpx}
.iitem{
  background:var(--surface);padding:8rpx 18rpx;
  border-radius:12rpx;font-size:26rpx;
  color:var(--text-secondary)
}
.slist{margin-top:8rpx}
.sitem{
  display:flex;gap:12rpx;margin-bottom:14rpx;
  font-size:26rpx;line-height:1.6
}
.snum{color:var(--primary);font-weight:bold;flex-shrink:0;min-width:40rpx}
.step-text{color:var(--text-secondary);flex:1}
.modal-ft{display:flex;gap:16rpx;margin-top:24rpx}
.btn{
  flex:1;height:80rpx;line-height:80rpx;
  text-align:center;color:#fff;
  background:var(--primary);border-radius:40rpx;
  font-size:28rpx
}
.btn-o{
  background:transparent;
  border:2rpx solid var(--primary);color:var(--primary)
}
