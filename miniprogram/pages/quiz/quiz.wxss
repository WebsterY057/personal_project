.quiz-container{padding:30rpx}
.progress-bar{height:8rpx;background:var(--border);border-radius:4rpx;overflow:hidden;margin-bottom:12rpx}
.progress-fill{height:100%;background:var(--primary);border-radius:4rpx}
.progress-text{font-size:24rpx;color:var(--text-muted);margin-bottom:30rpx;display:block}
.question-text{font-size:34rpx;font-weight:600;display:block;margin-bottom:30rpx;line-height:1.5}
.option{background:var(--surface);border:2rpx solid var(--border);border-radius:var(--radius);padding:28rpx;margin-bottom:16rpx;display:flex;align-items:center;justify-content:space-between}
.option.selected{border-color:var(--primary);background:rgba(76,175,80,.1)}
.option-text{font-size:28rpx;flex:1}
.radio{width:32rpx;height:32rpx;border-radius:50%;border:2rpx solid var(--border-light);flex-shrink:0}
.radio-on{background:var(--primary);border-color:var(--primary)}
.nav-btns{display:flex;justify-content:space-between}
.btn{padding:20rpx 40rpx;border-radius:var(--radius);font-size:28rpx;border:none;margin:0}
.btn-prev{background:var(--surface);color:var(--text)}
.btn-next,.btn-submit{background:var(--primary);color:#fff}
.symptom-container{padding:40rpx 30rpx}
.symptom-title{font-size:32rpx;font-weight:600;display:block;margin-bottom:20rpx}
.symptom-input{width:100%;height:240rpx;background:var(--surface);border:2rpx solid var(--border);border-radius:var(--radius);padding:24rpx;box-sizing:border-box;font-size:28rpx;color:var(--text)}
.symptom-hint{font-size:24rpx;color:var(--text-muted);margin:16rpx 0 30rpx;display:block}
.btn-skip{background:var(--surface);color:var(--text);margin-top:16rpx}
