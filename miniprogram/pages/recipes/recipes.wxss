.page{padding:0 30rpx 30rpx;background:var(--bg);color:var(--text)}

/* Hero Header */
.hero{
  background:var(--hero-bg);
  border-radius:var(--radius-lg);
  padding:28rpx 32rpx;
  margin-bottom:24rpx;
  border:1rpx solid var(--border);
  display:flex;align-items:center;gap:20rpx
}
.hero-title{
  display:block;
  font-size:34rpx;font-weight:500;
  font-family:KaiTi,STKaiti,serif;
  color:var(--accent);letter-spacing:2rpx;
  line-height:1.4
}
.hero-sub{display:block;font-size:22rpx;color:var(--text-muted);margin-top:4rpx}

/* 搜索框 */
.search-wrap{
  display:flex;align-items:center;
  background:var(--surface);
  border-radius:var(--radius);
  padding:16rpx 24rpx;
  margin-bottom:20rpx;
  border:1rpx solid rgba(255,255,255,0.06)
}
.si{font-size:28rpx;margin-right:12rpx;flex-shrink:0}
.sin{flex:1;font-size:28rpx;color:var(--text);background:transparent;padding:0}

/* 体质筛选 */
.frow{
  display:flex;align-items:center;
  margin-bottom:12rpx;overflow:hidden
}
.flabel{font-size:22rpx;color:var(--text-muted);margin-right:16rpx;flex-shrink:0;min-width:48rpx}
.fscroll{white-space:nowrap;flex:1}
.chip{
  display:inline-block;padding:8rpx 20rpx;
  margin-right:10rpx;font-size:24rpx;
  border-radius:20rpx;background:var(--surface);color:var(--text-muted)
}
.chip.act{background:var(--primary);color:#fff}

/* 列表 */
.rlist{margin-top:8rpx}
.rcard{
  background:var(--bg-card);
  border-radius:var(--radius);
  padding:24rpx;margin-bottom:16rpx;
  border:1rpx solid rgba(255,255,255,0.04)
}
.rch{display:flex;justify-content:space-between;align-items:center}
.rci{display:flex;align-items:flex-start;gap:16rpx}
.remoji{font-size:40rpx;flex-shrink:0;margin-top:4rpx}
.rn{font-size:30rpx;font-weight:bold;color:var(--text);display:block}
.rinfo{
  display:flex;gap:16rpx;
  font-size:22rpx;color:var(--text-muted);
  margin-top:6rpx
}
.fav{font-size:36rpx;color:var(--text-muted)}
.fav.faved{color:#FFB800}

.empty{color:var(--text-muted);font-size:28rpx;text-align:center;padding:80rpx 0}

/* 弹窗 */
.modal-overlay{
  position:fixed;top:0;left:0;right:0;bottom:0;
  background:rgba(0,0,0,.65);z-index:100
}
.modal{
  background:var(--bg);
  border-radius:var(--radius-lg);
  margin:100rpx 30rpx;
  padding:32rpx;
  max-height:75vh;overflow-y:auto
}
.modal-hd{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:24rpx;padding-bottom:16rpx;
  border-bottom:1rpx solid rgba(255,255,255,0.06)
}
.modal-title{
  font-size:32rpx;font-weight:bold;
  font-family:KaiTi,STKaiti,serif;letter-spacing:1rpx;
  color:var(--accent)
}
.modal-close{font-size:36rpx;color:var(--text-muted);padding:10rpx}
.modal-bd{
  max-height:60vh;overflow-y:auto;
  -webkit-overflow-scrolling:touch
}
.ms{margin-bottom:24rpx}
.ml{
  font-weight:bold;color:var(--accent);
  display:block;margin-bottom:12rpx;font-size:26rpx
}
.ilist2{display:flex;flex-direction:column;gap:12rpx;margin-top:8rpx}
.irow{
  display:flex;align-items:center;
  justify-content:space-between;
  background:var(--surface);
  border-radius:12rpx;
  padding:12rpx 18rpx
}
.iname{font-size:26rpx;color:var(--text-secondary)}
.ibtn{
  font-size:22rpx;
  color:var(--primary);
  border:1rpx solid var(--primary);
  border-radius:12rpx;
  padding:4rpx 18rpx;
  flex-shrink:0
}
.ibtn:active{background:var(--primary);color:#fff}
.slist{margin-top:8rpx}
.sitem{display:flex;gap:12rpx;margin-bottom:14rpx;font-size:26rpx;line-height:1.6}
.snum{color:var(--primary);font-weight:bold;flex-shrink:0;min-width:40rpx}
.step-text{color:var(--text-secondary);flex:1}
.modal-ft{display:flex;gap:16rpx;margin-top:24rpx}
.btn{
  flex:1;height:80rpx;line-height:80rpx;
  text-align:center;color:#fff;
  background:var(--primary);border-radius:40rpx;
  font-size:28rpx
}
.btn-o{
  background:transparent;
  border:2rpx solid var(--primary);color:var(--primary)
}
