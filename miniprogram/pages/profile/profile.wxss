.page{padding:30rpx}
.profile-header{display:flex;align-items:center;gap:20rpx;margin-bottom:30rpx}
.avatar{width:100rpx;height:100rpx;border-radius:50%;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:48rpx}
.pname{font-size:32rpx;font-weight:700;display:block}
.pstatus{font-size:24rpx;color:var(--text-muted);margin-top:4rpx;display:block}
.badge{display:flex;align-items:center;gap:14rpx;border-radius:var(--radius);padding:20rpx;margin-bottom:24rpx;font-size:44rpx}
.bname{font-size:28rpx;font-weight:600;display:block}
.bprinciple{font-size:22rpx;color:var(--text-muted);display:block}
.menu{background:var(--surface);border-radius:var(--radius);margin-bottom:20rpx}
.mitem{display:flex;align-items:center;padding:28rpx;border-bottom:1rpx solid var(--border, #333);gap:16rpx}
.mitem:last-child{border:none}
.micon{font-size:32rpx;width:40rpx}
.mtext{flex:1;font-size:28rpx}
.marrow{font-size:36rpx;color:var(--text-muted)}
.favorites{margin-bottom:20rpx}
.fcard{background:var(--surface);border-radius:var(--radius);padding:24rpx;margin-bottom:16rpx}
.ftitle{font-size:26rpx;font-weight:600;display:block;margin-bottom:12rpx}
.ftags{display:flex;flex-wrap:wrap;gap:8rpx}
.tag{display:inline-block;padding:6rpx 18rpx;border-radius:20rpx;font-size:22rpx;background:rgba(76,175,80,.12);color:var(--primary)}
.tag-r{background:rgba(255,82,82,.12);color:#FF5252}
.fempty{text-align:center;font-size:24rpx;color:var(--text-muted);padding:40rpx}