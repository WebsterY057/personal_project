.page{padding:0 30rpx 30rpx;background:var(--bg);color:var(--text)}

.hero{
  background:var(--hero-bg);
  border-radius:var(--radius-lg);
  padding:28rpx 32rpx;
  margin-bottom:24rpx;
  border:1rpx solid var(--border);
  display:flex;align-items:center;gap:20rpx
}
.hero-title{
  display:block;
  font-size:34rpx;font-weight:500;
  color:var(--warm);letter-spacing:2rpx;
  line-height:1.4
}
.hero-sub{display:block;font-size:22rpx;color:var(--text-muted);margin-top:4rpx}

.search-wrap{
  display:flex;align-items:center;
  background:var(--surface);
  border-radius:var(--radius);
  padding:16rpx 24rpx;
  margin-bottom:16rpx;
  border:1rpx solid var(--border)
}
.si{font-size:28rpx;margin-right:12rpx;flex-shrink:0}
.sin{flex:1;font-size:28rpx;color:var(--text);background:transparent;padding:0}

.cat-scroll{
  white-space:nowrap;
  margin-bottom:20rpx;
  padding:4rpx 0
}
.cat{
  display:inline-block;
  padding:12rpx 28rpx;
  margin-right:14rpx;
  font-size:26rpx;
  border-radius:24rpx;
  background:var(--surface);
  color:var(--text-secondary);
  border:1rpx solid var(--border)
}
.cat.act{
  background:var(--warm);
  color:#fff;
  border-color:var(--warm)
}

.glist{margin-top:8rpx}
.gcard{
  display:flex;
  gap:20rpx;
  background:var(--bg-card);
  border-radius:var(--radius);
  padding:24rpx;
  margin-bottom:16rpx;
  border:1rpx solid var(--border)
}
.gcard:active{background:var(--bg-card-hover)}
.gemoji{
  font-size:48rpx;
  width:80rpx;height:80rpx;
  display:flex;align-items:center;justify-content:center;
  background:var(--surface);
  border-radius:var(--radius-sm);
  flex-shrink:0
}
.ginfo{flex:1;min-width:0}
.gtop{
  display:flex;align-items:center;gap:10rpx;
  margin-bottom:6rpx
}
.gname{
  font-size:28rpx;font-weight:600;
  color:var(--text);display:block
}
.gtag{
  font-size:20rpx;
  background:rgba(196,154,108,0.15);
  color:var(--warm);
  padding:2rpx 14rpx;
  border-radius:12rpx;
  flex-shrink:0
}
.gdesc{
  font-size:24rpx;color:var(--text-muted);
  display:block;margin-bottom:12rpx;
  line-height:1.5
}
.gbottom{
  display:flex;align-items:center;
  justify-content:space-between
}
.gprice{
  font-size:32rpx;font-weight:700;
  color:var(--danger)
}
.gbtn{
  font-size:24rpx;
  background:var(--primary);
  color:#fff;
  padding:10rpx 24rpx;
  border-radius:16rpx
}

.tip{
  display:flex;align-items:center;gap:10rpx;
  background:var(--surface);
  border-radius:var(--radius-sm);
  padding:20rpx 24rpx;
  margin:20rpx 0 40rpx
}
.tip-icon{font-size:28rpx;flex-shrink:0}
.tip-text{
  font-size:22rpx;color:var(--text-muted);
  line-height:1.6
}
