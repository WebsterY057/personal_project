<view class="page">
  <view class="search"><input class="sin" placeholder="搜索食谱..." bindinput="onSearch" /></view>

  <view class="frow"><scroll-view class="fscroll" scroll-x><view class="chip {{filter===item?'act':''}}" wx:for="{{constitutions}}" wx:key="*this" data-value="{{item}}" bindtap="setFilter">{{item}}</view></scroll-view></view>

  <view class="rlist">
    <view wx:if="{{!hasData}}"><text class="empty">完整食谱数据请查看H5版</text></view>
    <view wx:elif="{{filtered.length===0}}"><text class="empty">未找到匹配食谱</text></view>
    <view class="rcard" wx:for="{{filtered}}" wx:key="key" data-key="{{item.key}}" bindtap="showRecipe">
      <view class="rch">
        <text class="rn">{{item.name}}</text>
        <view class="fav {{item.favorite?'faved':''}}" data-key="{{item.key}}" catchtap="toggleFavorite">♡</view>
      </view>
      <text class="re">{{item.effect}}</text>
      <view class="rtags">
        <text class="rtag" wx:for="{{item.constitutions}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="rinfo">
        <text>{{item.ingredients?item.ingredients.length:0}}种食材</text>
        <text>{{item.steps?item.steps.length:0}}个步骤</text>
      </view>
    </view>
  </view>

  <view class="modal-overlay" wx:if="{{showDetail}}" catchtap="closeModal">
    <view class="modal" catchtap="noop">
      <view class="modal-hd">
        <text class="modal-title">{{currentRecipe.name}}</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      <view class="modal-bd">
        <view class="ms"><text class="ml">功效</text><text>{{currentRecipe.effect}}</text></view>
        <view class="ms"><text class="ml">食材 ({{currentRecipe.ingredients.length}}种)</text>
          <view class="ilist"><view class="iitem" wx:for="{{currentRecipe.ingredients}}" wx:for-item="ing" wx:key="*this">{{ing}}</view></view>
        </view>
        <view class="ms"><text class="ml">步骤 ({{currentRecipe.steps.length}}步)</text>
          <view class="slist"><view class="sitem" wx:for="{{currentRecipe.steps}}" wx:for-item="step" wx:key="*this"><text class="snum">{{index+1}}.</text><text>{{step}}</text></view></view>
        </view>
      </view>
      <view class="modal-ft">
        <button class="btn" bindtap="copyList">复制购物清单</button>
        <button class="btn btn-o" bindtap="closeModal">关闭</button>
      </view>
    </view>
  </view>
</view>
