.page{padding:30rpx}
.tabs{display:flex;gap:12rpx;margin-bottom:24rpx}
.tab{flex:1;padding:16rpx 0;text-align:center;border-radius:var(--radius);background:var(--surface);font-size:26rpx;color:var(--text-secondary)}
.tab.active{color:#fff;font-weight:600}
.banner{background:var(--surface);border-radius:var(--radius);padding:28rpx;margin-bottom:20rpx}
.btitle{font-size:32rpx;font-weight:700;display:block;margin-bottom:8rpx}
.bstip{font-size:26rpx;color:var(--text-secondary);line-height:1.5}
.card{background:var(--surface);border-radius:var(--radius);padding:28rpx;margin-bottom:20rpx}
.ctitle{font-size:28rpx;font-weight:600;display:block;margin-bottom:8rpx}
.ceffect{font-size:24rpx;color:var(--primary);display:block;margin-bottom:6rpx}
.cdetail{font-size:24rpx;color:var(--text-muted);display:block;margin-bottom:16rpx}
.ingredients{margin-bottom:16rpx}
.ilabel{font-size:24rpx;color:var(--text-secondary);display:block;margin-bottom:8rpx}
.itags,.ftags{display:flex;flex-wrap:wrap;gap:10rpx}
.tag{display:inline-block;padding:6rpx 18rpx;border-radius:20rpx;font-size:22rpx;background:rgba(76,175,80,.12);color:var(--primary)}
.tag-f{background:rgba(33,150,243,.12);color:#42A5F5}
.copy-btn{margin-top:8rpx;padding:14rpx;border-radius:var(--radius);font-size:24rpx;background:var(--primary);color:#fff;border:none;width:100%;text-align:center}
.constitution-tip{background:var(--surface);border-radius:var(--radius);padding:24rpx;margin-bottom:20rpx;border-left:6rpx solid var(--primary)}
.ctip-title{font-size:26rpx;font-weight:600;display:block;margin-bottom:6rpx}
.ctip-text{font-size:24rpx;color:var(--text-secondary);line-height:1.5}