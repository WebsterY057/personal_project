.page{padding:30rpx}
.sin{background:var(--surface);border-radius:var(--radius);padding:20rpx 24rpx;font-size:28rpx;width:100%;box-sizing:border-box;color:var(--text)}
.frow{margin-bottom:12rpx}
.fscroll{white-space:nowrap}
.chip{display:inline-block;padding:10rpx 24rpx;margin-right:10rpx;font-size:24rpx;border-radius:20rpx;background:var(--surface);color:var(--text-secondary)}
.chip.act,.chip2.act{background:var(--primary);color:#fff}
.flist{margin-top:16rpx}
.fcard{background:var(--bg-card);border-radius:var(--radius);padding:20rpx;margin-bottom:16rpx}
.fch{display:flex;justify-content:space-between;align-items:center}
.fn{font-size:30rpx;font-weight:bold}
.ftags{margin-top:6rpx}
.ftag{display:inline-block;font-size:22rpx;color:var(--text-muted);background:var(--surface);border-radius:10rpx;padding:4rpx 12rpx;margin-right:6rpx;margin-top:4rpx}
.fca{display:flex;align-items:center;gap:12rpx}
.badge{padding:4rpx 12rpx;border-radius:10rpx;font-size:22rpx;font-weight:bold}
.bg{background:rgba(76,175,80,.2);color:var(--primary)}
.br{background:rgba(255,82,82,.2);color:#FF5252}
.fav{font-size:36rpx;color:var(--text-muted)}
.fav.faved{color:#FF5252}
.fbody{border-top:1rpx solid var(--border);margin-top:16rpx;padding-top:16rpx}
.fd{margin-bottom:12rpx;font-size:26rpx;color:var(--text-secondary);line-height:1.5}
.fl{font-weight:bold;color:var(--text)}
.empty{color:var(--text-muted);font-size:28rpx;text-align:center;padding:60rpx 0}
