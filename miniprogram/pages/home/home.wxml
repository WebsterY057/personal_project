<scroll-view class="container" scroll-y>
  <view class="header">
    <text class="greeting">{{greeting}} 👋</text>
    <text class="subtitle">今日宜养生</text>
  </view>

  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{foodCount}}</text>
      <text class="stat-label">食材库</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{constitutionCount}}</text>
      <text class="stat-label">种体质</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{checkinDays}}</text>
      <text class="stat-label">打卡天数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{hasResult ? currentConstitution.emoji : '—'}}</text>
      <text class="stat-label">{{hasResult ? currentConstitution.name : '未测评'}}</text>
    </view>
  </view>

  <view class="card daily-card" bindtap="go" data-url="/pages/food/food">
    <text class="card-title">🍽️ 今日推荐食材</text>
    <text class="daily-food">{{dailyFood}}</text>
    <text class="card-sub">查看食材详情及搭配建议</text>
  </view>

  <view class="card checkin-card" bindtap="doCheckin">
    <text class="card-title">{{checkedIn ? '✅ 已打卡' : '📅 每日打卡'}}</text>
    <text class="streak-text" wx:if="{{streak>0}}">已连续打卡 {{streak}} 天</text>
    <text class="streak-text" wx:else>开始健康打卡之旅</text>
  </view>

  <view class="card solar-card" wx:if="{{solarTerm}}">
    <text class="card-title">🌞 当前节气</text>
    <text class="solar-name">{{solarTerm.name}}</text>
  </view>

  <view class="grid">
    <view class="grid-item" bindtap="goQuiz">
      <text class="grid-icon">📋</text>
      <text class="grid-label">体质测试</text>
    </view>
    <view class="grid-item" bindtap="goTab" data-url="/pages/food/food">
      <text class="grid-icon">🥗</text>
      <text class="grid-label">食材查询</text>
    </view>
    <view class="grid-item" bindtap="go" data-url="/pages/season/season">
      <text class="grid-icon">🌱</text>
      <text class="grid-label">时令养生</text>
    </view>
    <view class="grid-item" bindtap="go" data-url="/pages/workout/workout">
      <text class="grid-icon">🏃</text>
      <text class="grid-label">运动营养</text>
    </view>
  </view>

  <view class="card constitution-card" wx:if="{{hasResult}}">
    <text class="card-title">🧬 当前体质</text>
    <view class="constitution-info">
      <text class="constitution-emoji">{{currentConstitution.emoji}}</text>
      <text class="constitution-name">{{currentConstitution.name}}</text>
    </view>
    <text class="constitution-principle">{{currentConstitution.principle}}</text>
  </view>

  <view class="card" wx:else>
    <text class="card-title">🧬 九种体质</text>
    <scroll-view scroll-x class="chip-scroll">
      <view class="chip" wx:for="{{constitutions}}" wx:key="id" style="border-color:{{item.color}}">
        <text>{{item.emoji}} {{item.name}}</text>
      </view>
    </scroll-view>
    <text class="card-sub" bindtap="goQuiz">点击开始体质测评 →</text>
  </view>

  <view class="disclaimer">本测评结果仅供参考，不构成医疗诊断建议。</view>
</scroll-view>
